---
interface Props {
  announce?: string;
}
const { announce = 'Now booking 1:1 sessions · 25 years helping people quit smoking & vaping' } = Astro.props;
---

<div class="announce">{announce}</div>
<nav class="nav">
  <div class="wrap">
    <a class="nav__logo" href="/">ALWAYS BE QUITTING</a>
    <button
      class="nav__toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span class="nav__bars" aria-hidden="true"></span>
    </button>
    <div class="nav__links" id="nav-links">
      <a href="/community">Community</a>
      <a href="/coaching">1:1 Coaching</a>
      <a href="/free-guide">Free Guide</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.querySelector('.nav__toggle');
  const links = document.getElementById('nav-links');
  btn?.addEventListener('click', () => {
    const open = links?.classList.toggle('is-open') ?? false;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
