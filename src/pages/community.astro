    color: var(--ink);
    border: 2px solid var(--ink);
    border-radius: 16px;
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    box-shadow: 12px 12px 0 var(--gold);
  }
  .ticket--big {
    padding: 2.4rem;
    gap: 0.8rem;
  }
  .ticket__kicker {
    font: 700 0.75rem/1 var(--font-body);
