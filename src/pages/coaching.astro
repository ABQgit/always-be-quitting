---
// /coaching — Quit for the Last Time: The 1:1 Program (+ $97 intro session entry)
// Copy base: old /premium-coaching page (canon), per one-on-one-page-spec.md rev 2026-07-11.
// Surgical changes only: typo fixes, "slave to nicotine" swap, one Program replaces
// two packages, no strikethrough pricing, no timeline claims.
// DIFFS FOR JON'S REVIEW are marked [DIFF] in comments.
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/home.css';
---

<Base
  title="1:1 Coaching — Quit for the Last Time | Always Be Quitting"
  description="Private 1:1 coaching with Jon Fritsch, CTTS & NCNTT certified tobacco treatment specialist. Start with a $97 intro session."
>
  <SiteHeader />

  <!-- hero: headline + video slot + trust line. [DIFF] H1 uses program name instead of "That Actually Works" -->
  <header class="band band--mist hero" style="padding-bottom: clamp(3rem, 6vw, 4.5rem)">
    <div class="wrap">
      <p class="kicker">Premium 1:1 coaching · You've tried before. It didn't last.</p>
      <h1 class="display-xl hl" style="margin-top:1.2rem">
        Quit for the Last Time — <em>1:1 coaching with Jon</em>
      </h1>
      <div class="video reveal" style="margin-top:2.2rem">
        [ Video — pending Jon's pick. "Please watch this video and see why 1:1 coaching is right for you." ]
      </div>
      <p class="trust">CTTS &amp; NCNTT certified · 25 years helping people quit · No one-size-fits-all programs</p>
    </div>
  </header>

  <!-- compressed pitch: the killer lines, excavated from the four paragraphs [DIFF: compression only, no new words except connectives] -->
  <section class="band band--white" style="padding-block: clamp(4rem, 8vw, 6rem)">
    <div class="wrap" style="max-width:820px">
      <h2 class="display-lg hl">This is not just <em>another quit attempt.</em></h2>
      <div class="pitch reveal">
        <p>
          I transform people into non-smokers and non-vapers using proven coaching techniques I've developed over
          25 years. The "magic formula" isn't a formula — it's expert guidance, accountability, and flexibility
          from someone who knows withdrawal symptom management and impactful behavior change techniques.
        </p>
        <p>
          You don't need to have it all figured out or be "ready enough" — that's what I'm here for.
        </p>
        <p>
          Quitting nicotine is one of the hardest things you will ever do. I've never seen a perfect quitting
          attempt. Coaching makes it easier, with less struggling and more success.
        </p>
        <p>
          <strong>I'm all-in with my clients. If you're ready to commit to changing your life, let's work together.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- what to expect: 8 bullets verbatim -->
  <section class="band band--paper" style="padding-block: clamp(4rem, 8vw, 6.5rem)">
    <div class="wrap">
      <h2 class="display-lg">What to Expect From 1:1 Coaching</h2>
      <div class="grid grid--2" style="margin-top:2.2rem">
        <div class="card reveal"><h3>1:1 access to Jon</h3><p>Leverage my 25 years of specialized experience in nicotine addiction</p></div>
        <div class="card reveal"><h3>Fluid quit plan</h3><p>Custom strategies that address your specific triggers and patterns</p></div>
        <div class="card reveal"><h3>Supportive coaching style</h3><p>Friendly and non-judgmental with the perfect mix of compassion AND the ability to move you forward</p></div>
        <div class="card reveal"><h3>Accountability partnership</h3><p>Regular check-ins that keep you progressing when motivation wavers</p></div>
        <div class="card reveal"><h3>Advanced mindset focus</h3><p>Develop the mental framework that makes quitting permanent</p></div>
        <div class="card reveal"><h3>Flexible scheduling options</h3><p>Easy software-based, with the flexibility to fit your life</p></div>
        <div class="card reveal"><h3>Whole-life approach</h3><p>We address how quitting integrates with your entire lifestyle — how work, relationships, daily routines, and personal goals all connect to quitting</p></div>
        <div class="card reveal"><h3>Support beyond quitting</h3><p>Sleep improvement, stress management, weight control, emotional challenges, relationship dynamics, and other life areas that affect your success (and generally make you happier)</p></div>
      </div>
    </div>
  </section>

  <!-- mechanics grid [DIFF: platform copy updated to true stack; packages card removed] -->
  <section class="band band--white" style="padding-block: clamp(4rem, 8vw, 6rem)">
    <div class="wrap">
      <h2 class="display-lg">How it works</h2>
      <div class="grid grid--3" style="margin-top:2.2rem">
        <div class="card card--pop reveal"><h3>1:1 Sessions</h3><p>Private 50-minute sessions with Jon, over video or phone</p></div>
        <div class="card card--pop reveal"><h3>Easy Scheduling</h3><p>Pick from a variety of times with the online scheduler</p></div>
        <div class="card card--pop reveal"><h3>Quit Date</h3><p>You generally set a quit date in the first 1–3 weeks. You can also begin having already started quitting</p></div>
        <div class="card card--pop reveal"><h3>Simple Video Sessions</h3><p>One click to join — no accounts or downloads to wrestle with</p></div>
        <div class="card card--pop reveal"><h3>Email Support</h3><p>Update Jon on your progress and get guidance between sessions</p></div>
        <div class="card card--pop reveal"><h3>Progress Tracking</h3><p>Keep your plans and support documents in one convenient place we share</p></div>
      </div>
    </div>
  </section>

  <!-- pays for itself — verbatim, with the approved swap [DIFF: "slave to nicotine" -> "controlled by nicotine"; duplicate headline bug fixed] -->
  <section class="band band--teal transform" style="text-align:left">
    <div class="wrap" style="max-width:880px">
      <h2 class="display-xl hl" style="text-align:center">Premium 1:1 Coaching <em>Pays for Itself</em></h2>
      <div class="pitch reveal" style="margin-top:2rem">
        <p>
          The average smoker and vaper spends thousands of dollars every year on cigarettes and vapes, and rarely
          gives it much thought. That steady, outgoing cash flow continues year-after-year with nothing positive
          to show for it.
        </p>
        <p>
          How much did you spend on cigarettes or vapes last year? And the year before? And the year before that?
        </p>
        <p><strong>When you are successful at quitting, you will:</strong></p>
        <ul class="checks">
          <li>SAVE tens of thousands, if not hundreds of thousands, of dollars in the future.</li>
          <li>Improve your physical health dramatically.</li>
          <li>Stop feeling controlled by nicotine.</li>
          <li>Increase productivity and energy in your professional and personal life.</li>
          <li>Increase your quality of life.</li>
          <li>and dozens of others.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- THE OFFER: $97 session first, Program beneath -->
  <section class="band band--paper doors">
    <div class="wrap">
      <div class="doors__mega reveal" aria-hidden="true">$97</div>
      <h2 class="display-lg hl">Start with one session. <em>See for yourself.</em></h2>
      <div class="grid grid--2" style="margin-top:3rem">
        <div class="door door--session reveal">
          <h3>The $97 Intro Session</h3>
          <p>The simplest way to work with Jon — private, direct, one time.</p>
          <div class="price">$97 one-time</div>
          <p>50 minutes · video or phone · <strong>once per person, ever</strong> — it's a starting point, not a product you re-buy.</p>
          <p>Your $97 is always credited toward the Program if you continue. No deadline.</p>
          <a class="btn btn--cta" href="#book">Book your session</a>
        </div>
        <div class="door door--community reveal">
          <h3>Quit for the Last Time: The 1:1 Program</h3>
          <p>The full transformation, with Jon in your corner the whole way.</p>
          <div class="price">$1,200</div>
          <p>6 × 50-minute private sessions over 12 weeks — a roomy window, because life happens. Email access to Jon between sessions. Personalized quit strategy, behavior change and withdrawal management, progress tracking.</p>
          <p>Ready now? You can start with the full Program directly. Alumni can add sessions at $150 whenever more support helps.</p>
          <a class="btn btn--cta" href="#book">Start the Program</a>
        </div>
      </div>
      <p class="doors__foot">Prefer group support? <a href="/community">The ABQ Community</a> is $97/month with a 3-month commitment.</p>
    </div>
  </section>

  <!-- Katherine long-form, verbatim -->
  <section class="band band--white proof">
    <div class="wrap" style="max-width:880px">
      <p class="kicker">How coaching made the difference — Katherine's experience</p>
      <figure class="card quote reveal" style="margin-top:2rem">
        <blockquote>
          The most difficult aspect of quitting that Jon helped me overcome was personal accountability. As many
          people who vape can relate to, I wanted to quit for years and tried countless times to no avail. I felt
          like I was constantly at war with myself, stuck weighing the pros and cons. On one side, I could ease
          the withdrawal symptoms for a moment by vaping — but at the cost of facing my own disappointment. On
          the other, I was staring down a painful, uncertain journey, unsure if I even had what it took to succeed.
          <br /><br />
          Jon was my outlet, a safe person who let me talk through this internal battle, who shared the weight,
          pressure, and frightening solitude I originally felt in my quit journey. There were many moments
          throughout our work together that I didn't believe I could do it. I was determined to quit vaping but
          terrified of the withdrawal process. Jon was very receptive to these worries; he provided reassuring
          research, perspectives, and options I could take.
          <br /><br />
          What surprised me most about working with Jon was his approach to quitting. I intensified my own worries
          by looking at the whole journey (the rest of my life) at once. Jon not only broke down the process but
          acted as my biggest supporter, always making himself a readily available outlet. I walked away from my
          sessions with confidence, understanding, and ways to move forward.
          <br /><br />
          I believe I was successful this time because of Jon. It took me nearly six years to build the courage to
          find a specialist and I am unbelievably grateful it was Jon. If you have reservations about investing in
          a coach, I cannot recommend Jon enough. The impact he has had on my life is transformative — I have no
          doubt that he can do the same for you.
        </blockquote>
        <figcaption><b>Katherine R.</b> · One Year Vape Free</figcaption>
      </figure>
    </div>
  </section>

  <!-- failure stakes close — verbatim, formatting fixed, offer name updated -->
  <section class="band band--mist" style="padding-block: clamp(4rem, 8vw, 6rem); text-align:center">
    <div class="wrap" style="max-width:820px">
      <h2 class="display-lg reveal">
        You can continue to spend $1k, $2k, $3k, $4k every year on cigarettes and vapes. You can continue to make
        yourself physically and mentally sick. And next year at this time, you'll wish you had started today.
      </h2>
    </div>
  </section>

  <!-- FAQ — drafted from Jon's language; ALL ITEMS PENDING JON'S COPY APPROVAL -->
  <section class="band band--white">
    <div class="wrap faq">
      <h2 class="display-lg">A few things people usually ask.</h2>
      <details class="reveal">
        <summary>Why can I only book the $97 session once?</summary>
        <p>Because it's a starting point, not a product you re-buy. One session is for finding out how we'd work together. From there, the Program, add-on sessions, or the community are the real paths. [draft — Jon to approve]</p>
      </details>
      <details class="reveal">
        <summary>Does the $97 count toward the Program?</summary>
        <p>Yes, always. If you continue into the Program, your $97 comes off the price — no deadline, no fine print. [draft — Jon to approve]</p>
      </details>
      <details class="reveal">
        <summary>What if I need to reschedule?</summary>
        <p>Life happens. You can reschedule up to 24 hours before your session, no questions asked. Inside 24 hours I can't refund the session, but I'll credit it toward the Program — because I can't rebook your time slot. [carried from current policy]</p>
      </details>
      <details class="reveal">
        <summary>Is this the same as the community?</summary>
        <p>No. This is private 1:1 work with me. The ABQ Community is group support with weekly live calls — some people do both, many pick one. If you're not sure which fits, ask me in a session or through the contact page and I'll give you a straight answer, including "neither, yet." [draft — Jon to approve]</p>
      </details>
      <details class="reveal">
        <summary>Do I have to sign up for anything ongoing?</summary>
        <p>No. Nothing is automatic. If, after we work together, I think ongoing coaching or the community would help you, I'll tell you — and you decide from there. [draft — Jon to approve]</p>
      </details>
    </div>
  </section>

  <!-- final CTA -->
  <section class="band band--teal final" id="book">
    <div class="wrap">
      <h2 class="display-xl hl">Always be quitting, <em>until you've quit for the last time.</em></h2>
      <p style="margin-top:1.4rem; color: color-mix(in srgb, var(--white) 82%, transparent)">
        [ Cal.com booking embed lands here in the integrations milestone ]
      </p>
      <div class="final__actions reveal">
        <a class="btn btn--cta" href="#book">Book the $97 Session</a>
        <a class="btn btn--ghost" href="#book">Start the Program</a>
      </div>
    </div>
  </section>

  <SiteFooter />
</Base>

<style>
  .video {
    max-width: 720px;
    margin-inline: auto;
    aspect-ratio: 16/9;
    border: 2px solid var(--ink);
    border-radius: 14px;
    background: repeating-linear-gradient(45deg, var(--alt), var(--alt) 10px, var(--white) 10px, var(--white) 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--soft);
    font-size: 0.95rem;
    padding: 1rem;
    text-align: center;
    box-shadow: 12px 12px 0 color-mix(in srgb, var(--teal) 30%, transparent);
  }
  .pitch p {
    font-size: 1.15rem;
    line-height: 1.65;
    margin: 1.1rem 0;
  }
  .band--teal .pitch p {
    color: color-mix(in srgb, var(--white) 88%, transparent);
  }
  .checks {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }
  .checks li {
    padding-left: 1.9rem;
    position: relative;
    margin: 0.55rem 0;
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--white) 90%, transparent);
  }
  .checks li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 800;
  }
</style>
